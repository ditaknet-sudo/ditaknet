# Optional — only needed if you use compose variable substitution locally.
# TrueNAS Custom App YAML (truenas/docker-compose.yml) uses hardcoded paths
# and a pinned image tag so paste-install works without a .env file.
#
# Never commit a filled .env with real secrets.

# Must match a tag that exists on GHCR (verify before deploy).
DITAKNET_VERSION=2.0.1

# Persistent host paths (create these datasets/folders on TrueNAS first)
DITAKNET_DATA_PATH=/mnt/tank/apps/ditaknet/data
DITAKNET_LOGS_PATH=/mnt/tank/apps/ditaknet/logs
DITAKNET_BACKUPS_PATH=/mnt/tank/apps/ditaknet/backups
DITAKNET_PLUGINS_PATH=/mnt/tank/apps/ditaknet/plugins

# Optional notify-only update checks (never auto-replace the container)
# DITAKNET_UPDATE_CHECK_ENABLED=true
# DITAKNET_UPDATE_CHANNEL=stable
# DITAKNET_UPDATE_CHECK_INTERVAL_HOURS=6
# DITAKNET_UPDATE_MANIFEST_URL=https://raw.githubusercontent.com/ditaknet-sudo/ditaknet/main/update-manifest.json
