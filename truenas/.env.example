# DitakNet TrueNAS Custom App — environment template
# Copy to .env next to the compose file and edit paths for your pool.
# Never commit a filled .env with real secrets.

# Image tag. Prefer a stable SemVer for production (matches GitHub release v2.0.0 → 2.0.0).
# Use "latest" only for testing.
DITAKNET_VERSION=2.0.0

# Persistent host paths (create these datasets/folders on TrueNAS first)
DITAKNET_DATA_PATH=/mnt/tank/apps/ditaknet/data
DITAKNET_LOGS_PATH=/mnt/tank/apps/ditaknet/logs
DITAKNET_BACKUPS_PATH=/mnt/tank/apps/ditaknet/backups
DITAKNET_PLUGINS_PATH=/mnt/tank/apps/ditaknet/plugins
