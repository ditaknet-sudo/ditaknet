# DitakNet TrueNAS Custom App — environment template
# Copy to .env next to the compose file and edit paths for your pool.
# Never commit a filled .env with real secrets.

# Image tag. Use the exact stable SemVer matching the GitHub release
# (v2.0.1 → 2.0.1); floating tags are unsupported.
DITAKNET_VERSION=2.0.1
DITAKNET_UPDATE_CHANNEL=stable

# Bridge mode only. Set a specific TrueNAS LAN IP to avoid listening on every
# interface. Host-network mode always listens on the TrueNAS host port below.
DITAKNET_BIND_ADDRESS=0.0.0.0
DITAKNET_PORT=5833
TZ=Etc/UTC

# Persistent host paths (create these datasets/folders on TrueNAS first)
DITAKNET_DATA_PATH=/mnt/tank/apps/ditaknet/data
DITAKNET_LOGS_PATH=/mnt/tank/apps/ditaknet/logs
DITAKNET_BACKUPS_PATH=/mnt/tank/apps/ditaknet/backups
DITAKNET_PLUGINS_PATH=/mnt/tank/apps/ditaknet/plugins

# The deployment runs as the fixed non-root apps identity 568:568. Grant this UID
# and GID read/write/execute access to every dataset above before deployment.
# Do not make the datasets world-writable and do not place secrets in this file.
