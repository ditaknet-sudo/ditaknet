# DitakNet monitoring server — environment template
# Copy optional overrides into your container platform / TrueNAS UI.
# Non-secret defaults live in config/runtime.env.
#
# Do NOT put real passwords, session keys, API tokens, or private keys here.
# User passwords are stored only as hashes in the database. DitakNet generates
# a persistent session signing key under /app/data when no external secret is set.

# --- Core (normally set via config/runtime.env or image defaults) ---
# APP_HOST=0.0.0.0
# APP_PORT=5833
# APP_ENV=production
# APP_VERSION=2.0.2
# DATABASE_URL=sqlite:////app/data/ditaknet.db
# DATA_DIR=/app/data
# LOG_DIR=/app/logs
# BACKUP_DIR=/app/backups
# PLUGIN_DIR=/app/plugins
# LOG_LEVEL=INFO
# SCHEDULER_ENABLED=true

# --- Optional public URL / CORS (examples only) ---
# APP_BASE_URL=https://ditaknet.example.com
# CORS_ALLOWED_ORIGINS=https://ditaknet.example.com
# SESSION_COOKIE_SECURE=true

# --- Optional LAN discovery helpers ---
# DISCOVERY_DNS_SERVERS=192.168.1.1

# --- Optional update checks (notify-only; never auto-applies containers) ---
# DITAKNET_UPDATE_CHECK_ENABLED=true
# DITAKNET_UPDATE_CHANNEL=stable  # stable or beta
# DITAKNET_UPDATE_CHECK_INTERVAL_HOURS=6
# Official stable/beta feeds are selected automatically from the channel.
# DITAKNET_UPDATE_MANIFEST_URL=  # optional custom HTTPS feed override
# DITAKNET_UPDATE_CHECK_TIMEOUT_SECONDS=8
# DITAKNET_UPDATE_SIGNATURE_REQUIRED=true
# DITAKNET_UPDATE_PUBLIC_KEYRING_PATH=
# Legacy/private feeds only; never distribute this HMAC signing secret in a public image:
# DITAKNET_UPDATE_MANIFEST_SIGNING_KEY=
# Legacy aliases still work: APP_UPDATE_CHECK_ENABLED, APP_UPDATE_CHECK_URL

# --- Docker Compose image/network/storage overrides ---
# DITAKNET_VERSION=2.0.2
# DITAKNET_BIND_ADDRESS=0.0.0.0
# DITAKNET_PORT=5833
# Named volumes below are the safe defaults for a new installation.
# Legacy repository Compose upgrades must set all four sources to their
# existing data/logs/backups/plugins paths before the first new-container start.
# See docs/UPGRADE.md; never migrate only the SQLite file from a live container.
# DITAKNET_DATA_SOURCE=ditaknet-data
# DITAKNET_LOGS_SOURCE=ditaknet-logs
# DITAKNET_BACKUPS_SOURCE=ditaknet-backups
# DITAKNET_PLUGINS_SOURCE=ditaknet-plugins
# A *_SOURCE may instead be an absolute host path. Its owner/ACL must grant
# UID:GID 568:568 write access before the first container start.
# DITAKNET_DATA_SOURCE=/srv/ditaknet/data

# --- TrueNAS Custom App image/path overrides (see also truenas/.env.example) ---
# DITAKNET_DATA_PATH=/mnt/tank/apps/ditaknet/data
# DITAKNET_LOGS_PATH=/mnt/tank/apps/ditaknet/logs
# DITAKNET_BACKUPS_PATH=/mnt/tank/apps/ditaknet/backups
# DITAKNET_PLUGINS_PATH=/mnt/tank/apps/ditaknet/plugins
